# Postgres
POSTGRES_USER=colorstrades
POSTGRES_PASSWORD=changeme
POSTGRES_DB=colorstrades

# Prisma / Next.js
DATABASE_URL=postgresql://colorstrades:changeme@db:5432/colorstrades?schema=public

# NextAuth
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Seed credentials (single-user self-host)
SEED_EMAIL=owner@local
SEED_PASSWORD=changeme

# Server-side encryption key for LLM provider API keys stored in the DB.
# MUST be 64 hex chars (32 bytes). Generate with:
#   openssl rand -hex 32
# Changing this value invalidates all previously saved LLM keys.
ENCRYPTION_KEY=

# Display
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC
