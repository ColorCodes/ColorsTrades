# =============================================================================
# ColorsTrades environment template
#
# Copy to .env and fill in EVERY value. docker compose will refuse to start
# if any required variable is missing — that's intentional.
#
# Generate strong secrets with:
#   NEXTAUTH_SECRET:    openssl rand -base64 32
#   ENCRYPTION_KEY:     openssl rand -hex 32    (must be exactly 64 hex chars)
#   POSTGRES_PASSWORD:  openssl rand -base64 24
#   SEED_PASSWORD:      pick a strong password; rotate via /settings after login
#
# NEVER commit .env. NEVER reuse defaults in production.
# =============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=colorstrades
POSTGRES_PASSWORD=
POSTGRES_DB=colorstrades

# --- Prisma ----------------------------------------------------------------
# Must match the Postgres creds above. The hostname `db` is the compose service.
DATABASE_URL=postgresql://colorstrades:REPLACE_ME@db:5432/colorstrades?schema=public

# --- NextAuth --------------------------------------------------------------
NEXTAUTH_SECRET=
# Public URL where the app is reachable. For production behind a reverse
# proxy use https://your-domain. For local dev use http://localhost:3000.
NEXTAUTH_URL=http://localhost:3000

# --- Initial user (seeded on first boot; change the password after login) --
SEED_EMAIL=owner@local
SEED_PASSWORD=

# --- Server-side encryption key for stored LLM API keys --------------------
# MUST be exactly 64 hex chars (32 bytes).
# Changing this value invalidates every LLM key already stored in the DB.
ENCRYPTION_KEY=

# --- Display (optional) ----------------------------------------------------
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC
